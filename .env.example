# PactStream — Environment variables
# Copia este archivo a .env y rellena con tus credenciales reales.
# NUNCA commits .env al repositorio.

# ============ SUPABASE ============
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
# Service role key SOLO se usa en Edge Functions del lado servidor, NUNCA en el cliente Flutter
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ============ MANGOPAY ============
MANGOPAY_CLIENT_ID=pactstream_sandbox
MANGOPAY_API_KEY=
MANGOPAY_BASE_URL=https://api.sandbox.mangopay.com

# ============ ONFIDO ============
ONFIDO_API_TOKEN=api_sandbox.xxxxx
ONFIDO_REGION=eu
ONFIDO_WORKFLOW_ID=

# ============ SIGNATURIT ============
SIGNATURIT_API_TOKEN=
SIGNATURIT_BASE_URL=https://api.sandbox.signaturit.com/v3

# ============ FIREBASE (push notifications) ============
FCM_PROJECT_ID=
FCM_API_KEY=

# ============ EMAIL (Resend / SendGrid) ============
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=no-reply@pactstream.io

# ============ MONITORING ============
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
SENTRY_ENVIRONMENT=development

# ============ ANALYTICS ============
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# ============ APP CONFIG ============
ENVIRONMENT=development
LOG_LEVEL=debug
ENABLE_BIOMETRIC_AUTH=true
